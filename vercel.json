{
  "version": 2,
  "builds": [
    { "src": "api/login.py",             "use": "@vercel/python" },
    { "src": "api/users.py",             "use": "@vercel/python" },
    { "src": "api/clients.py",           "use": "@vercel/python" },
    { "src": "api/camps.py",             "use": "@vercel/python" },
    { "src": "api/infl_corrections.py",  "use": "@vercel/python" },
    { "src": "api/data.py",              "use": "@vercel/python" },
    { "src": "api/health.py",            "use": "@vercel/python" },
    { "src": "frontend/public/**",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/login",                   "dest": "/api/login.py" },
    { "src": "/api/gestao/users",            "dest": "/api/users.py" },
    { "src": "/api/gestao/clients",          "dest": "/api/clients.py" },
    { "src": "/api/gestao/camps",            "dest": "/api/camps.py" },
    { "src": "/api/gestao/infl-corrections", "dest": "/api/infl_corrections.py" },
    { "src": "/api/gestao/data",             "dest": "/api/data.py" },
    { "src": "/health",                      "dest": "/api/health.py" },
    { "src": "/",                            "dest": "/frontend/public/index.html" },
    { "src": "/(.*)",                        "dest": "/frontend/public/$1" }
  ]
}
